# Required for DB (Neon / Supabase / any PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Optional: only for migrating data from Supabase to Neon (see NEON_SETUP.md)
# SUPABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Optional: server port (default 5000)
# PORT=5000

# Optional: SMS, Email, Push, Google, etc. – see NEON_SETUP.md and server code
# FAST2SMS_API_KEY=
# SMTP_HOST= SMTP_PORT= SMTP_USER= SMTP_PASS=
# VAPID_PUBLIC_KEY= VAPID_PRIVATE_KEY=
# GOOGLE_CLIENT_ID= GOOGLE_SERVICE_ACCOUNT_KEY=

# Group audio/video calls (Livekit Cloud or self-hosted)
# LIVEKIT_URL=wss://patiala-rural-xxxxx.livekit.cloud
# LIVEKIT_API_KEY= LIVEKIT_API_SECRET=
